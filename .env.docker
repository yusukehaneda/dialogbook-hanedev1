# ローカル Docker 環境用 環境変数
# このファイルを .env にコピーして使用してください
# cp .env.docker .env

# PostgreSQL のパスワード（任意の文字列）
POSTGRES_PASSWORD=your_db_password_here

# Rails master key（config/master.key の内容をそのままコピー）
RAILS_MASTER_KEY=your_master_key_here

# SECRET_KEY_BASE（64文字以上のランダム文字列）
# 既存の値がある場合はそのまま使用可
SECRET_KEY_BASE=your_secret_key_base_here
